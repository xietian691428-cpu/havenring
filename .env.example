# --- Public (browser-safe; set in Vercel / hosting dashboard) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site URL for metadata / OG (production: https://havenring.me)
NEXT_PUBLIC_SITE_URL=https://havenring.me
# Supabase Auth → URL Configuration: add every OAuth return origin you use, e.g.
#   https://www.havenring.me/login   https://havenring.me/login
#   https://www.havenring.me/start   https://havenring.me/start
#   https://www.havenring.me/app     https://havenring.me/app
# (Website sign-in uses /login; the memory app uses /start and /app.)

# Optional: Amazon PDP for Ritual Ring (secondary path; replace PLACEHOLDER ASIN when live)
# NEXT_PUBLIC_AMAZON_RITUAL_RING_URL=https://www.amazon.com/dp/YOUR_ASIN

# --- Shop checkout (PayPal + order emails) ---
# PayPal Developer Dashboard → create app → Sandbox/Live credentials
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
# sandbox | live (default sandbox)
PAYPAL_MODE=sandbox

# Order notification (merchant) — defaults to hello@havenring.me
# SHOP_ORDER_NOTIFY_EMAIL=hello@havenring.me

# Transactional email via Resend (https://resend.com) — required for real emails
RESEND_API_KEY=
# SHOP_EMAIL_FROM=HavenRing Orders <orders@havenring.me>

# --- Server-only (never expose to the client) ---
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Optional NFC / JWT overrides — see README
# SUPABASE_JWT_ISS=
# SDM_BACKEND_URL=
# MASTER_KEY=
